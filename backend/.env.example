# =============================================================================
# CreatorIQ Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
# Connection string for PostgreSQL database with pgvector extension
# Format: postgresql://user:password@host:port/database_name
# 
# IMPORTANT: Enable pgvector extension on your database:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://user:password@localhost:5432/creatoriq

# -----------------------------------------------------------------------------
# Redis Configuration (Celery Broker)
# -----------------------------------------------------------------------------
# Redis connection string for Celery background task broker
# Format: redis://host:port/db_number
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# OpenAI Configuration
# -----------------------------------------------------------------------------
# API key for OpenAI services (GPT-4o, embeddings, etc.)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# OpenRouter Configuration
# -----------------------------------------------------------------------------
# API key for OpenRouter (unified API for multiple LLM providers)
# Get from: https://openrouter.ai/keys
# OpenRouter provides access to models from OpenAI, Anthropic, Meta, Mistral, etc.
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# Default model for content generation (free as of May 2026)
# Free options verified live: gemma-4-31b, nemotron-3-super-120b, llama-3.3-70b
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Vision model for thumbnail/image analysis (multimodal free model)
VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Embedding model — OpenRouter doesn't proxy embeddings reliably; uses direct OpenAI
EMBEDDING_MODEL=openai/text-embedding-3-small

# OpenRouter site info (for analytics on OpenRouter dashboard)
OPENROUTER_SITE_URL=https://creatoriq.app
OPENROUTER_SITE_NAME=CreatorIQ

# -----------------------------------------------------------------------------
# MiniMax Token Plan / Coding Plan Configuration
# -----------------------------------------------------------------------------
# This is for the Token Plan subscription (NOT pay-as-you-go).
# Uses the OpenAI-compatible API endpoint.
# Get key from: https://platform.minimax.io → Billing → Token Plan
#
# Note: Token Plan keys are NOT interchangeable with pay-as-you-go API keys.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_MODEL_FAST=MiniMax-M2

# -----------------------------------------------------------------------------
# YouTube Data API v3
# -----------------------------------------------------------------------------
# API key for YouTube Data API v3
# Get from: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Quota: 10,000 units/day (channels.list = 1, videos.list = 1, search = 100)
YOUTUBE_API_KEY=your-youtube-api-key

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=generate_with_openssl_rand_hex_32

# Algorithm for JWT signing (HS256 is recommended for symmetric signing)
ALGORITHM=HS256

# Access token expiration time in minutes (10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development | staging | production
ENVIRONMENT=development

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth 2.0 Configuration
# -----------------------------------------------------------------------------
# OAuth credentials for YouTube channel connection
# Get from: https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile, https://www.googleapis.com/auth/youtube.readonly
#
# Setup instructions: https://developers.google.com/identity/protocols/oauth2/web-server
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Rate Limiting (Future Use)
# -----------------------------------------------------------------------------
# To enable rate limiting, install slowapi:
#   pip install slowapi
#
# Rate limits by plan:
#   free: 100 requests/minute
#   starter: 500 requests/minute  
#   pro: 1000 requests/minute
#   agency: 5000 requests/minute
# RATE_LIMIT_ENABLED=false
# DEFAULT_RATE_LIMIT=100/minute

# -----------------------------------------------------------------------------
# Celery Configuration (Future Use)
# -----------------------------------------------------------------------------
# For production Celery workers, configure these:
# CELERY_WORKER_CONCURRENCY=4
# CELERY_TASK_TIME_LIMIT=1800  # 30 minutes max per task
# CELERY_TASK_SOFT_TIME_LIMIT=1500  # 25 minutes soft limit

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Whisper API for video transcription (if using OpenAI Whisper)
# WHISPER_API_KEY=your-whisper-api-key

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://example@sentry.io/project

# -----------------------------------------------------------------------------
# Database Pool Configuration (Advanced)
# -----------------------------------------------------------------------------
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# DATABASE_POOL_PRE_PING=true