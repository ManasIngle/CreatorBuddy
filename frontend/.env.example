# =============================================================================
# CreatorIQ Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local files to version control
# .env.local is already in .gitignore

# -----------------------------------------------------------------------------
# NextAuth.js Configuration
# -----------------------------------------------------------------------------
# The canonical URL of your site
NEXTAUTH_URL=http://localhost:3000

# Secret for NextAuth.js signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# -----------------------------------------------------------------------------
# Backend API Configuration
# -----------------------------------------------------------------------------
# Base URL for the CreatorIQ backend API (no trailing slash)
# In development: http://localhost:8000/api/v1
# In production: https://api.creatoriq.io/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Google OAuth Configuration (Client-side)
# -----------------------------------------------------------------------------
# OAuth client ID for Google Sign-In
# Get from: https://console.cloud.google.com/apis/credentials
# Must match the CLIENT_ID configured in backend/.env
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# Feature Flags (Future Use)
# -----------------------------------------------------------------------------
# Enable/disable specific features
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_AUDIO_TRANSCRIPTION=false

# -----------------------------------------------------------------------------
# Analytics Configuration (Future Use)
# -----------------------------------------------------------------------------
# Plausible Analytics for privacy-friendly analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=creatoriq.io

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ENVIRONMENT=development